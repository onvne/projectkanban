<div class="dashboard">
  <!-- Левая панель с проектами -->
  <aside class="sidebar">
    <div class="sidebar-header">
      <h2>📁 Проекты</h2>
      <%= link_to new_project_path, class: "btn-new-project" do %>
        <i class="fas fa-plus"></i> Новый
      <% end %>
    </div>
    
    <nav class="projects-nav">
      <!-- Кнопка "Все проекты" -->
      <%= link_to root_path, class: "project-link #{'active' if @selected_project.nil?}" do %>
        <span class="project-icon">📊</span>
        <span class="project-name">Все проекты</span>
        <span class="project-count"><%= current_user.tasks.count %></span>
      <% end %>
      
      <!-- Список проектов -->
      <% @projects.each do |project| %>
        <%= link_to root_path(project_id: project.id), 
                    class: "project-link #{'active' if @selected_project&.id == project.id}" do %>
          <span class="project-icon" style="color: <%= project.color %>">●</span>
          <span class="project-name"><%= project.name %></span>
          <span class="project-count"><%= project.tasks.count %></span>
        <% end %>
      <% end %>
    </nav>
  </aside>
  
  <!-- Основная область - Канбан-доска -->
  <main class="main-content">
    <div class="board-header">
      <h1>
        <%= @selected_project ? @selected_project.name : "Все проекты" %>
        <span class="task-count"><%= @tasks.count %> задач</span>
      </h1>
      
      <%= link_to new_project_task_path(@selected_project || current_user.projects.first), 
                  class: "btn-add-task", 
                  data: { turbo_frame: "modal" } do %>
        <i class="fas fa-plus"></i> Новая задача
      <% end %>
    </div>
    
    <div class="kanban-board">
      <!-- Колонка To Do -->
      <%= render 'column', status: 'todo', label: '📝 To Do', tasks: @tasks.where(status: 'todo') %>
      
      <!-- Колонка In Progress -->
      <%= render 'column', status: 'in_progress', label: '🔄 In Progress', tasks: @tasks.where(status: 'in_progress') %>
      
      <!-- Колонка In Testing -->
      <%= render 'column', status: 'in_testing', label: '🧪 In Testing', tasks: @tasks.where(status: 'in_testing') %>
      
      <!-- Колонка Rejected -->
      <%= render 'column', status: 'rejected', label: '❌ Rejected', tasks: @tasks.where(status: 'rejected') %>
      
      <!-- Колонка Done -->
      <%= render 'column', status: 'done', label: '✅ Done', tasks: @tasks.where(status: 'done') %>
    </div>
  </main>
</div>