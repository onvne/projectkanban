<div class="project-form-wrapper">
  <div class="project-form-card">
    
    <div class="form-header">
      <h2>Create New Project</h2>
      <p>Give your project a clear name to start organizing tasks.</p>
    </div>

    <%= form_with(model: @project, local: true, class: "auth-form") do |f| %>
      
      <% if @project.errors.any? %>
        <div id="error_explanation">
          <h2><%= pluralize(@project.errors.count, "error") %> prohibited this project from being saved:</h2>
          <ul>
            <% @project.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="field">
        <%= f.label :title, "Project Title" %>
        <%= f.text_field :title, placeholder: "e.g., Mobile App, Website Redesign...", autofocus: true, required: true %>
      </div>
      
      <div class="field">
        <%= f.label :description, "Description (Optional)" %>
        <%= f.text_area :description, placeholder: "Describe the goals, links, or notes for this project...", rows: 4, class: "form-textarea" %>
      </div>
      
      <div class="form-actions">
        <%= link_to "Cancel", root_path, class: "btn-cancel" %>
        <%= f.submit "Create Project", class: "auth-btn-submit" %>
      </div>

    <% end %>

  </div>
</div>