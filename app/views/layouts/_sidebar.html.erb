<aside class="kv-sidebar">
  <div class="sidebar-top">
    <div class="sidebar-logo">
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="24" height="24" rx="6" fill="#6d5dfc"/>
        <path d="M7 7H11V11H7V7Z" fill="white" opacity="0.6"/>
        <path d="M13 7H17V17H13V7Z" fill="white"/>
        <path d="M7 13H11V17H7V13Z" fill="white" opacity="0.8"/>
      </svg>
    </div>

    <div class="projects-section">
      <div class="section-header">
        <span class="section-title">Projects</span>
      </div>

      <button class="sidebar-new-project-btn" onclick="document.getElementById('project-modal').showModal()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        <span>New Project</span>
      </button>

      <ul class="projects-list">
        <li class="project-item <%= 'active' if @project.nil? %>">
          <%= link_to root_path, class: "project-link", data: { turbo_frame: "board_frame", turbo_action: "advance" } do %>
            <span class="project-title-wrapper">
              <span class="project-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
              </span>
              All Projects
            </span>
            <span class="project-badge">
              <%= current_user.tasks.count %>
            </span>
          <% end %>
        </li>

        <% dot_colors = ['purple', 'teal', 'orange'] %>
        <% @projects.each_with_index do |project, index| %>
          <% active_class = (@project == project) ? 'active' : '' %>
          <% color_class = dot_colors[index % dot_colors.length] %>
          
          <li class="project-item <%= active_class %>">
            <%= link_to project_tasks_path(project), class: "project-link", data: { turbo_frame: "board_frame", turbo_action: "advance" } do %>
              <span class="project-title-wrapper">
                <span class="project-dot dot-<%= color_class %>"></span>
                <%= project.title %>
              </span>
              <span class="project-badge">
                <%= project.tasks.count %>
              </span>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>

  <div class="sidebar-footer">
    <div class="profile-container">
      <div class="profile-avatar">
        <%= current_user.email[0..1].upcase %>
      </div>
      <div class="profile-details">
        <span class="profile-name"><%= current_user.email.split('@').first.titleize %></span>
        <span class="profile-tasks">
          <%= current_user.tasks.where.not(status: :done).count %> active tasks
        </span>
      </div>
    </div>
    <%= button_to destroy_user_session_path, method: :delete, class: "logout-icon-btn", title: "Log Out" do %>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ff4a5a" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
    <% end %>
  </div>
</aside>