<div class="kanban-card" id="<%= dom_id(task) %>">
  <%= link_to edit_task_path(task), data: { turbo_frame: "modal_frame" }, class: "edit-button-class" do %>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
      <path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4z"></path>
    </svg>
  <% end %>

  <div class="card-tags-row"></div>

  <div class="card-body">
    <h4 class="card-title"><%= task.title %></h4>
    <% if task.respond_to?(:description) && task.description.present? %>
      <p class="card-description"><%= truncate(task.description, length: 75) %></p>
    <% end %>
  </div>

  <div class="card-meta-row">
    <div class="priority-indicator">
      <% priority_name = "High" %>
      <% if task.respond_to?(:priority) && task.priority.present? %>
        <% priority_name = task.priority.to_s.humanize %>
      <% end %>
      <span class="priority-dot priority-high"></span>
      <span class="priority-text"><%= priority_name %></span>
    </div>

    <div class="due-date-indicator">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
        <line x1="16" y1="2" x2="16" y2="6"></line>
        <line x1="8" y1="2" x2="8" y2="6"></line>
        <line x1="3" y1="10" x2="21" y2="10"></line>
      </svg>
      <span>
        <% if task.respond_to?(:due_date) && task.due_date.present? %>
          <%= task.due_date.strftime("%d %b") %>
        <% else %>
          18 Jul
        <% end %>
      </span>
    </div>
  </div>

  <div class="card-footer-row"></div>

  <div class="card-transitions">
    <% if task.can_move_backward? %>
      <%= button_to move_backward_task_path(task), method: :patch, class: "transition-arrow-btn" do %>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      <% end %>
    <% end %>

    <% if task.can_move_forward? %>
      <%= button_to move_forward_task_path(task), method: :patch, class: "transition-arrow-btn" do %>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      <% end %>
    <% end %>
  </div>
</div>
