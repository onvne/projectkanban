<div class="kanban-column">
  <div class="column-header">
    <h2><%= label %></h2>
    <span class="column-count"><%= tasks.size %></span>
  </div>

  <% tasks.each do |task| %>
    <div class="task-card">
      <h3><%= task.title %></h3>
      <p><%= truncate(task.description, length: 120) %></p>
      <div class="task-actions">
        <%= link_to "Редактировать", edit_project_task_path(task.project, task), class: "btn-small" %>
        <%= button_to "Удалить", project_task_path(task.project, task), method: :delete, data: { confirm: "Уверены?" }, class: "btn-small btn-danger" %>
      </div>
    </div>
  <% end %>
</div>
